{
  "manifest_version": 3,
  "name": "TruthLens Sidepanel",
  "version": "1.0",
  "description": "Multi-agent fact-checking and news verification sidepanel.",
  "permissions": [
    "sidePanel",
    "tabs",
    "scripting",
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open TruthLens"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
     {
       "matches": ["<all_urls>"],
       "js": ["content.js"]
     },
     {
       "matches": ["<all_urls>"],
       "js": ["overlay.js"]
     }
  ],
  "externally_connectable": {
    "matches": ["*://localhost/*"]
  }
}
