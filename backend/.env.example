# TruthLens Environment Variables

# AI Models
GEMINI_API_KEY=your_gemini_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# Translation
LINGODEV_API_KEY=your_lingodev_api_key_here

# Search & Fact-Checking
GOOGLE_FACT_CHECK_API_KEY=your_google_fact_check_api_key_here
GOOGLE_CUSTOM_SEARCH_API_KEY=your_google_custom_search_api_key_here
GOOGLE_CUSTOM_SEARCH_CX=your_google_custom_search_cx_here
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here
SERPAPI_API_KEY=your_serpapi_api_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./truthlens.db
REDIS_URL=redis://localhost:6379/0

# Bots
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Webhook Security
WEBHOOK_SECRET=your_secure_random_string_here

# Blockchain (TruthLens Social Ledger)
RPC_URL=https://api-mezame.shardeum.org
CHAIN_ID=8119
PRIVATE_KEY=your_shardeum_wallet_private_key_here
REPUTATION_CONTRACT_ADDRESS=your_reputation_contract_address_here
DAO_CONTRACT_ADDRESS=your_dao_contract_address_here
INTEGRITY_CONTRACT_ADDRESS=your_integrity_contract_address_here
BRIDGE_CONTRACT_ADDRESS=your_bridge_contract_address_here
SOCIAL_CONTRACT_ADDRESS=your_social_contract_address_here
QUESTS_CONTRACT_ADDRESS=your_quests_contract_address_here
